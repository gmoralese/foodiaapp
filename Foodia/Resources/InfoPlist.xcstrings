      }
    },
    "NSHealthShareUsageDescription" : {
      "comment" : "Privacy - Health Share Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Foodia does not read Health data; it only writes your logged meals."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Foodia no lee datos de Salud; solo escribe tus comidas registradas."
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "comment" : "Privacy - Health Update Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Foodia writes your meals' calories and macros to Apple Health if you enable syncing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Foodia escribe las calorías y macros de tus comidas en Apple Salud, si activas la sincronización."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Foodia uses the microphone so you can dictate context about your meal (for example, what dish it is or the portion size)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Foodia usa el micrófono para que puedas dictar contexto sobre tu comida (por ejemplo, qué plato es o el tamaño de la porción)."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Foodia transcribes your voice on your iPhone to add context to the food analysis."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Foodia transcribe tu voz en el iPhone para agregar contexto al análisis de la comida."
