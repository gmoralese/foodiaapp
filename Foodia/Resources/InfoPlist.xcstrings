    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Foodia uses the camera to photograph your food and estimate its macros."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Foodia usa la cámara para fotografiar tu comida y estimar sus macros."
